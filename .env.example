# ============================================================
# Cannon - AI Web Pentesting Agent Configuration
# ============================================================
# Copy this file to .env and fill in your values.
#
# LLM Provider (pick one or more)
# Supported: openai, anthropic, gemini, openrouter
# ============================================================

# --- Provider API Keys ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# --- Model Configuration ---
# Use litellm model format:
#   OpenAI:      gpt-4o, gpt-4o-mini
#   Anthropic:   claude-sonnet-4-20250514
#   Gemini:      gemini/gemini-2.0-flash
#   OpenRouter:  openrouter/anthropic/claude-sonnet-4-20250514
CANNON_MODEL=openrouter/anthropic/claude-sonnet-4-20250514

# --- Agent Settings ---
CANNON_MAX_ITERATIONS=50
CANNON_TIMEOUT=300

# --- Logging ---
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
CANNON_LOG_LEVEL=INFO
# Write a full debug log file to the output directory
CANNON_LOG_FILE=true

# --- Output ---
CANNON_OUTPUT_DIR=./results
